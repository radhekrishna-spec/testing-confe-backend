{
  "name": "confession-saas-node-v7-webhookless-max",
  "version": "2.0.0",
  "description": "Production-ready webhookless confession SaaS with Telegram approval, Google Drive/Slides integration, and worker queue",
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "workers": "node src/workers/index.js",
    "dev:all": "concurrently \"nodemon src/server.js\" \"nodemon src/workers/index.js\"",
    "lint": "eslint .",
    "clean": "rimraf logs generated/temp",
    "restart": "npm run clean && npm run dev:all"
  },
  "keywords": [
    "nodejs",
    "telegram-bot",
    "saas",
    "confession-app",
    "google-slides",
    "worker-queue",
    "instagram-auto-post"
  ],
  "author": "Ashu Singh",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.8.4",
    "compression": "^1.7.5",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "form-data": "^4.0.5",
    "fs-extra": "^11.3.0",
    "googleapis": "^148.0.0",
    "helmet": "^8.1.0",
    "mongoose": "^9.4.1",
    "morgan": "^1.10.0",
    "node-cron": "^3.0.3",
    "p-queue": "^8.1.0",
    "razorpay": "^2.9.6",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "eslint": "^9.24.0",
    "nodemon": "^3.1.14",
    "rimraf": "^6.0.1"
  }
}
